# Kopiere diese Datei nach .env.local und trage deine Supabase-Werte ein.
# WICHTIG: Nur die NEUE KWD-Instanz verwenden – keine anderen Projekte!

VITE_SUPABASE_URL=https://dein-projekt-id.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-key-hier

# Optional: KI-Wartungsplan aus PDF + Plan-Foto-Erkennung (gpt-4o-mini Vision)
# Erstellen unter https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-...

# Optional: Edge Function statt Client-KI (Production empfohlen)
VITE_USE_EDGE_AI=false
